# ─── Django ───────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# ─── Database ─────────────────────────────────────────────────
POSTGRES_DB=marketintel
POSTGRES_USER=marketintel
POSTGRES_PASSWORD=marketintel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://marketintel:marketintel@postgres:5432/marketintel

# ─── Cache & broker ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Object storage (MinIO / S3) ──────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BRONZE_BUCKET=bronze
S3_SILVER_BUCKET=silver
S3_GOLD_BUCKET=gold
S3_REGION=us-east-1

# ─── Third-party APIs ─────────────────────────────────────────
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
COINGECKO_RATE_LIMIT_PER_MIN=30

BINANCE_BASE_URL=https://api.binance.com
BINANCE_RATE_LIMIT_PER_MIN=1200

CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/v1
CRYPTOPANIC_API_KEY=

# ─── Observability ────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=marketintel
SENTRY_DSN=

# ─── Feature flags ────────────────────────────────────────────
ENABLE_DAGSTER_SENSORS=True
ENABLE_DLQ_REQUEUE=False
